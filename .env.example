# Optional Confab proxy. The URL below is the built-in default.
CONFAB_API_KEY=
CONFAB_URL=http://localhost:8000

# GitHub username the agent-interface review tooling acts as. Shown
# as the owner of the "Review New Pull Requests" behavior so the user
# can see WHO will be commenting on their PRs.
REVIEW_AGENT_USERNAME=

# Production server. Poise deliberately supports loopback hosts only.
POISE_HOST=127.0.0.1
POISE_PORT=5555

# Optional storage overrides. Blank values use ~/.poise defaults.
# POISE_DB=/absolute/path/to/cache.db
# POISE_EDITOR_DIR=/absolute/path/to/editor
# POISE_CHAT_ATTACHMENTS_DIR=/absolute/path/to/chat-attachments
# POISE_ESPANSO_MATCH_DIR=/absolute/path/to/espanso/match

# agent-interface project root and optional writer voice guide.
# AGENT_INTERFACE_ROOT=/absolute/path/to/agent_interface
# AGENT_INTERFACE_DATA_DIR=/absolute/path/to/durable/agent-interface/data
# POISE_VOICE_GUIDE_PATH=/absolute/path/to/voice-guide.md
